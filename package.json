{
  "name": "trail-docs",
  "version": "1.1.0",
  "description": "Local-first CLI for agent-friendly documentation navigation and pre-install library research",
  "type": "module",
  "bin": {
    "trail-docs": "src/cli.mjs"
  },
  "files": [
    "src",
    "docs/*.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:index": "node ./src/cli.mjs build --src fixtures/docs --library acme-payments --version 2.4.1 --out .trail-docs/index.json --json",
    "eval:smoke": "node ./eval/src/run-eval.mjs --profile smoke --allow-missing-context7",
    "eval:iterative-smoke": "node ./eval/src/run-eval.mjs --profile iterative-smoke --allow-missing-context7",
    "eval:smoke:ci": "node ./eval/src/run-eval.mjs --profile smoke --config eval/config/eval.config.ci.json --allow-missing-context7",
    "eval:check-gates": "node ./eval/src/check-gates.mjs",
    "eval:full": "node ./eval/src/run-eval.mjs --profile full",
    "eval:report": "node ./eval/src/report.mjs",
    "test": "node --test",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "toml": "^3.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Arkology Studio (https://arkology.studio)",
  "license": "MIT",
  "homepage": "https://github.com/arkologystudio/trail-docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/arkologystudio/trail-docs.git"
  },
  "bugs": {
    "url": "https://github.com/arkologystudio/trail-docs/issues"
  },
  "keywords": [
    "cli",
    "documentation",
    "ai-agent",
    "developer-tools",
    "search",
    "citations",
    "agentic",
    "context-window",
    "code-navigation",
    "llm-tools",
    "openclaw"
  ]
}
